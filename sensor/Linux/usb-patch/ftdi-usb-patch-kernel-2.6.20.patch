+	{ USB_DEVICE(FTDI_VID, FTDI_NDI_FUTURE_3_PID),
+		.driver_info = (kernel_ulong_t)&ftdi_NDI_HUC_quirk },	
 	{ },					/* Optional parameter entry */
 	{ }					/* Terminating entry */
 };
@@ -787,7 +816,7 @@
 
 static __u32 get_ftdi_divisor(struct usb_serial_port * port)
 { /* get_ftdi_divisor */
-	struct ftdi_private *priv = usb_get_serial_port_data(port);
+ struct ftdi_private *priv = usb_get_serial_port_data(port);
 	__u32 div_value = 0;
 	int div_okay = 1;
 	int baud;
@@ -833,7 +862,7 @@
 
 	if (!baud) baud = 9600;
 	switch(priv->chip_type) {
-	case SIO: /* SIO chip */
+ case SIO: /* SIO chip */
 		switch(baud) {
 		case 300: div_value = ftdi_sio_b300; break;
 		case 600: div_value = ftdi_sio_b600; break;
@@ -854,7 +883,7 @@
 		break;
 	case FT8U232AM: /* 8U232AM chip */
 		if (baud <= 3000000) {
-			div_value = ftdi_232am_baud_to_divisor(baud);
+			div_value = ftdi_232am_baud_to_divisor(baud);			
 		} else {
 	                dbg("%s - Baud rate too high!", __FUNCTION__);
 			div_value = ftdi_232am_baud_to_divisor(9600);
@@ -863,7 +892,15 @@
 		break;
 	case FT232BM: /* FT232BM chip */
 	case FT2232C: /* FT2232C chip */
-		if (baud <= 3000000) {
+  if (baud <= 3000000) 
+  {
+						__u16 product_id = le16_to_cpu(port->serial->dev->descriptor.idProduct);
+						if (((FTDI_NDI_HUC_PID == product_id) ||
+					(FTDI_NDI_SPECTRA_SCU_PID == product_id) ||
+					(FTDI_NDI_FUTURE_2_PID == product_id) ||
+					(FTDI_NDI_FUTURE_3_PID == product_id)) && (baud == 19200)) {
+						baud = 1200000;
+			}
 			div_value = ftdi_232bm_baud_to_divisor(baud);
 		} else {
 	                dbg("%s - Baud rate too high!", __FUNCTION__);
@@ -947,6 +984,7 @@
 			port->tty->alt_speed = 460800;
 		else
 			port->tty->alt_speed = 0;
+
 	}
 	if (((old_priv.flags & ASYNC_SPD_MASK) !=
 	     (priv->flags & ASYNC_SPD_MASK)) ||
@@ -1009,7 +1047,7 @@
 		/* Assume its an FT232BM (or FT245BM) */
 		priv->chip_type = FT232BM;
 	}
-	info("Detected %s", ftdi_chip_name[priv->chip_type]);
