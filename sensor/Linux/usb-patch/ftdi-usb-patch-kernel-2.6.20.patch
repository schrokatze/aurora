 };
 
+static struct ftdi_sio_quirk ftdi_NDI_HUC_quirk = {
+	.setup = ftdi_NDI_HUC_setup,
+};
+
 /*
  * The 8U232AM has the same API as the sio except for:
  * - it can support MUCH higher baudrates; up to:
