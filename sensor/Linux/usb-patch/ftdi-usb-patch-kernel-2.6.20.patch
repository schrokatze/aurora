 }
 
 
@@ -1262,6 +1300,37 @@
 	priv->force_rtscts = 1;
 } /* ftdi_HE_TIRA1_setup */
 
+/* Setup for the NDI HUC device, which requires hardwired
+ * baudrate (19200 gets mapped to 1200000) */
+/* Called from usbserial:serial_probe */
+static void ftdi_NDI_HUC_setup (struct usb_serial *serial)
+{
+	struct usb_device *udev = serial->dev;
+	int latency = ndi_latency_timer;
+	int rv = 0;
+	char buf[1];
+	struct ftdi_private *priv;
+
+	if (latency == 0 ) latency = 1;
+	if (latency > 99 ) latency = 99;
+	priv = usb_get_serial_port_data(serial->port[0]);
+
+	dbg("%s setting NDI_HUC latency to %d",__FUNCTION__, latency );
+	
+	info( "NDI Device with a latency value of %d", latency );	
+
+	rv = usb_control_msg(udev, usb_sndctrlpipe(udev, 0), 
+	                     FTDI_SIO_SET_LATENCY_TIMER_REQUEST,
+	                     FTDI_SIO_SET_LATENCY_TIMER_REQUEST_TYPE,
+	                     latency, priv->interface, buf, 0, WDR_TIMEOUT);
+
+	    if (rv < 0) 
+    {
+		dev_err(&(serial->port[0]->dev), "Unable to write latency timer: %i", rv);
+    }
+    
+} /* ftdi_NDI_HUC_setup */
+
 
 /* ftdi_shutdown is called from usbserial:usb_serial_disconnect
  *   it is called when the usb device is disconnected
@@ -2208,6 +2277,7 @@
 		goto failed_usb_register;
 
 	info(DRIVER_VERSION ":" DRIVER_DESC);
+
 	return 0;
 failed_usb_register:
 	usb_serial_deregister(&ftdi_sio_device);
@@ -2242,3 +2312,6 @@
 module_param(product, ushort, 0);
 MODULE_PARM_DESC(vendor, "User specified product ID");
 
+module_param(ndi_latency_timer, int, S_IRUGO | S_IWUSR);
+MODULE_PARM_DESC(ndi_latency_timer, "NDI HUC message latency timer");
+
